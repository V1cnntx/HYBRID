/* ============================================
   HYBRID CULTURE — MAIN JS
   GSAP + ScrollTrigger animations
   ============================================ */

'use strict';

// ── GSAP REGISTRATION ─────────────────────── //
gsap.registerPlugin(ScrollTrigger);

// ── DATA LOADER ───────────────────────────── //
async function loadData() {
  try {
    const res = await fetch('/data/hybrid-culture.json');
    return await res.json();
  } catch {
    // fallback to embedded data if fetch fails (local dev)
    return window.__HC_DATA__ || {};
  }
}

// ── HERO ENTRANCE ─────────────────────────── //
function animateHero() {
  const tl = gsap.timeline({ delay: 0.2 });

  tl.from('.hero__badge', {
    opacity: 0,
    y: 20,
    duration: 0.6,
    ease: 'power3.out'
  })
  .from('.hero__title .line-1', {
    opacity: 0,
    y: 80,
    duration: 0.9,
    ease: 'power4.out'
  }, '-=0.3')
  .from('.hero__title .line-2', {
    opacity: 0,
    y: 80,
    duration: 0.9,
    ease: 'power4.out'
  }, '-=0.7')
  .from('.hero__sub', {
    opacity: 0,
    y: 30,
    duration: 0.7,
    ease: 'power3.out'
  }, '-=0.5')
  .from('.hero__actions', {
    opacity: 0,
    y: 20,
    duration: 0.6,
    ease: 'power3.out'
  }, '-=0.4')
  .from('.hero__scroll-hint', {
    opacity: 0,
    duration: 0.5
  }, '-=0.2')
  .from('.hero__bg-grid', {
    opacity: 0,
    scale: 1.05,
    duration: 1.5,
    ease: 'power2.out'
  }, 0);

  // Parallax glow
  gsap.to('.hero__glow', {
    y: 100,
    ease: 'none',
    scrollTrigger: {
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1
    }
  });
}

// ── MANIFESTO PINNED SCROLL ─────────────────── //
function animateManifesto() {
  const section = document.querySelector('.section-manifesto');
  if (!section) return;

  const words = section.querySelectorAll('.manifesto__word');

  gsap.from(words, {
    opacity: 0.1,
    stagger: 0.08,
    ease: 'none',
    scrollTrigger: {
      trigger: section,
      start: 'top 80%',
      end: 'bottom 20%',
      scrub: 1
    }
  });

  gsap.from('.manifesto__body', {
    opacity: 0,
    x: 60,
    duration: 1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: section,
      start: 'top 60%',
      toggleActions: 'play none none reverse'
    }
  });
}

// ── CATEGORY TABS SCROLL-DRIVEN ────────────── //
function animateCategories(data) {
  const section = document.querySelector('.section-categories');
  if (!section || !data.categories) return;

  const panels = section.querySelectorAll('.category-panel');
  const tabBtns = section.querySelectorAll('.tab-btn');

  function activateTab(index) {
    panels.forEach((p, i) => {
      p.classList.toggle('active', i === index);
    });
    tabBtns.forEach((b, i) => {
      b.classList.toggle('active', i === index);
    });
  }

  tabBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => activateTab(i));
  });

  activateTab(0);

  // Scroll-driven tab switching with pinned section
  const totalScrollDist = window.innerHeight * data.categories.length;

  ScrollTrigger.create({
    trigger: section,
    start: 'top top',
    end: `+=${totalScrollDist}`,
    pin: true,
    scrub: 0.5,
    onUpdate: (self) => {
      const idx = Math.floor(self.progress * data.categories.length);
      const clampedIdx = Math.min(idx, data.categories.length - 1);
      activateTab(clampedIdx);
    }
  });

  // Animate each panel in
  panels.forEach((panel) => {
    gsap.from(panel.querySelectorAll('.reveal-item'), {
      opacity: 0,
      y: 40,
      stagger: 0.1,
      duration: 0.7,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
        toggleActions: 'play none none none'
      }
    });
  });
}

// ── DIFFERENTIATORS ───────────────────────── //
function animateDiff() {
  gsap.from('.diff-item', {
    opacity: 0,
    y: 50,
    stagger: 0.1,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.diff-grid',
      start: 'top 75%',
      toggleActions: 'play none none reverse'
    }
  });
}

// ── KPI SECTION ───────────────────────────── //
function animateKPIs(data) {
  if (!data.kpis) return;

  // Stagger the KPI items on scroll
  gsap.from('.kpi-item', {
    opacity: 0,
    y: 30,
    stagger: 0.15,
    duration: 0.7,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.section-kpi',
      start: 'top 70%',
      toggleActions: 'play none none reverse'
    }
  });

  // Counters
  const counters = document.querySelectorAll('.kpi-item__number[data-counter]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !entry.target.dataset.animated) {
        entry.target.dataset.animated = 'true';
        const target = parseFloat(entry.target.dataset.counter);
        const suffix = entry.target.dataset.suffix || '';
        const prefix = entry.target.dataset.prefix || '';

        gsap.fromTo(entry.target, {
          textContent: 0
        }, {
          textContent: target,
          duration: 2,
          ease: 'power2.out',
          snap: { textContent: 1 },
          onUpdate() {
            const val = Math.round(parseFloat(this.targets()[0].textContent));
            this.targets()[0].textContent = prefix + val.toLocaleString() + suffix;
          }
        });
      }
    });
  }, { threshold: 0.6 });

  counters.forEach(el => observer.observe(el));
}

// ── CHART INITIALIZATION ───────────────────── //
function initChart(data) {
  const canvas = document.getElementById('growth-chart');
  if (!canvas || !data.growth) return;

  let chartInitialized = false;

  ScrollTrigger.create({
    trigger: '#growth-chart',
    start: 'top 80%',
    onEnter: () => {
      if (chartInitialized) return;
      chartInitialized = true;

      const ctx = canvas.getContext('2d');

      const gradient = ctx.createLinearGradient(0, 0, 0, 380);
      gradient.addColorStop(0, 'rgba(200, 255, 0, 0.25)');
      gradient.addColorStop(1, 'rgba(200, 255, 0, 0)');

      const gradient2 = ctx.createLinearGradient(0, 0, 0, 380);
      gradient2.addColorStop(0, 'rgba(255, 69, 0, 0.2)');
      gradient2.addColorStop(1, 'rgba(255, 69, 0, 0)');

      const chart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: data.growth.labels,
          datasets: [
            {
              label: 'Seguidores (×100)',
              data: data.growth.followers.map(v => v / 100),
              borderColor: '#c8ff00',
              backgroundColor: gradient,
              borderWidth: 2.5,
              pointBackgroundColor: '#c8ff00',
              pointRadius: 4,
              pointHoverRadius: 7,
              fill: true,
              tension: 0.4
            },
            {
              label: 'Revenue (×1K CLP)',
              data: data.growth.revenue,
              borderColor: '#ff4500',
              backgroundColor: gradient2,
              borderWidth: 2,
              pointBackgroundColor: '#ff4500',
              pointRadius: 3,
              pointHoverRadius: 6,
              fill: true,
              tension: 0.4
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: {
            duration: 1500,
            easing: 'easeInOutQuart'
          },
          interaction: { intersect: false, mode: 'index' },
          plugins: {
            legend: {
              labels: {
                color: '#7a7a7a',
                font: { family: 'Barlow Condensed', size: 11, weight: '600' },
                boxWidth: 12
              }
            },
            tooltip: {
              backgroundColor: '#1e1e1e',
              titleColor: '#c8ff00',
              bodyColor: '#efefef',
              borderColor: 'rgba(255,255,255,0.08)',
              borderWidth: 1,
              padding: 12,
              titleFont: { family: 'Bebas Neue', size: 16 },
              bodyFont: { family: 'Barlow', size: 12 }
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.04)' },
              ticks: {
                color: '#555',
                font: { family: 'Barlow Condensed', size: 10, weight: '600' }
              }
            },
            y: {
              grid: { color: 'rgba(255,255,255,0.04)' },
              ticks: {
                color: '#555',
                font: { family: 'Barlow Condensed', size: 10 }
              }
            }
          }
        }
      });

      // Animate chart drawing
      gsap.from(canvas, { opacity: 0, duration: 0.5 });
    }
  });
}

// ── GENERIC REVEAL ANIMATIONS ─────────────── //
function initRevealAnimations() {
  // Section labels
  gsap.utils.toArray('.label').forEach(el => {
    gsap.from(el, {
      opacity: 0,
      x: -20,
      duration: 0.6,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        toggleActions: 'play none none reverse'
      }
    });
  });

  // Generic reveal elements
  gsap.utils.toArray('.reveal').forEach(el => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.9,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
        toggleActions: 'play none none reverse'
      }
    });
  });

  // Section titles
  gsap.utils.toArray('.section-title-anim').forEach(el => {
    gsap.from(el, {
      opacity: 0,
      y: 60,
      duration: 1,
      ease: 'power4.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
        toggleActions: 'play none none reverse'
      }
    });
  });
}

// ── CLOSING SECTION ───────────────────────── //
function animateClose() {
  const section = document.querySelector('.section-close');
  if (!section) return;

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: section,
      start: 'top 60%',
      toggleActions: 'play none none reverse'
    }
  });

  tl.from('.close__logo', {
    opacity: 0,
    scale: 0.8,
    duration: 1.2,
    ease: 'power4.out'
  })
  .from('.close__message', {
    opacity: 0,
    y: 20,
    duration: 0.7,
    ease: 'power3.out'
  }, '-=0.6')
  .from('.close__cta-group', {
    opacity: 0,
    y: 20,
    duration: 0.6,
    ease: 'power3.out'
  }, '-=0.4');

  // Pin closing section
  ScrollTrigger.create({
    trigger: section,
    start: 'top top',
    end: '+=80%',
    pin: true,
    pinSpacing: true
  });
}

// ── MARQUEE HOVER PAUSE ────────────────────── //
function initMarquee() {
  const track = document.querySelector('.marquee-track');
  if (!track) return;
  const wrap = track.closest('.marquee-wrap');
  wrap?.addEventListener('mouseenter', () => track.style.animationPlayState = 'paused');
  wrap?.addEventListener('mouseleave', () => track.style.animationPlayState = 'running');
}

// ── MAIN INIT ─────────────────────────────── //
async function init() {
  const data = await loadData();

  // Store data globally for fallback
  window.__HC_DATA__ = data;

  // Populate dynamic content
  populateKPIs(data);
  populateCategories(data);
  populateDifferentiators(data);

  // Animations (after DOM is populated)
  animateHero();
  animateManifesto();
  animateCategories(data);
  animateDiff();
  animateKPIs(data);
  initChart(data);
  animateClose();
  initRevealAnimations();
  initMarquee();

  // Refresh ScrollTrigger after all content
  ScrollTrigger.refresh();
}

// ── DYNAMIC DOM POPULATION ─────────────────── //
function populateKPIs(data) {
  const grid = document.querySelector('.kpi-grid');
  if (!grid || !data.kpis) return;
  grid.innerHTML = data.kpis.map(kpi => `
    <div class="kpi-item">
      <span class="kpi-item__number"
        data-counter="${kpi.value}"
        data-suffix="${kpi.suffix}"
        data-prefix="${kpi.prefix}"
      >${kpi.prefix}0${kpi.suffix}</span>
      <span class="kpi-item__label">${kpi.label}</span>
    </div>
  `).join('');
}

function populateCategories(data) {
  const panelsWrap = document.querySelector('.category-panels');
  const tabsHeader = document.querySelector('.categories-tabs');
  if (!panelsWrap || !data.categories) return;

  // Tabs
  if (tabsHeader) {
    tabsHeader.innerHTML = data.categories.map((cat, i) => `
      <button class="tab-btn${i === 0 ? ' active' : ''}">${cat.icon} ${cat.label}</button>
    `).join('');
  }

  // Panels
  panelsWrap.innerHTML = data.categories.map((cat, i) => `
    <div class="category-panel${i === 0 ? ' active' : ''}" id="cat-${cat.id}">
      <div class="category-panel__content">
        <div class="category-panel__icon reveal-item">${cat.icon}</div>
        <div class="category-panel__tagline reveal-item">${cat.tagline}</div>
        <h3 class="category-panel__title reveal-item">${cat.label}</h3>
        <p class="category-panel__desc reveal-item">${cat.description}</p>
        <ul class="products-list reveal-item">
          ${cat.products.map(p => `<li class="products-list__item">${p}</li>`).join('')}
        </ul>
      </div>
      <div class="category-panel__visual reveal-item">
        <div class="phone-cluster">
          <div class="phone">
            <div class="phone__screen">
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#111,#1e1e1e);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#c8ff00;letter-spacing:0.05em;">HC</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;letter-spacing:0.2em;color:#555;text-transform:uppercase;">${cat.label}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  `).join('');
}

function populateDifferentiators(data) {
  const grid = document.querySelector('.diff-grid');
  if (!grid || !data.differentiators) return;
  grid.innerHTML = data.differentiators.map((d, i) => `
    <div class="diff-item">
      <div class="diff-item__num">0${i + 1}</div>
      <div class="diff-item__title">${d.title}</div>
      <p class="diff-item__desc">${d.desc}</p>
    </div>
  `).join('');
}

// ── BOOT ──────────────────────────────────── //
document.addEventListener('DOMContentLoaded', init);
